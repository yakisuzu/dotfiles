{
  "permissions": {
    "allow": [
      "Bash(git diff --stat)",
      "Bash(git diff --cached --stat)"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session_register.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_say.js"
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "autoUpdatesChannel": "stable",
  "skipAutoPermissionPrompt": true
}
